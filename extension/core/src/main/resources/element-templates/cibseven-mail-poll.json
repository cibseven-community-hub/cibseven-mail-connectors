{
  "$schema": "https://unpkg.com/@camunda/element-templates-json-schema/resources/schema.json",
  "name": "CIB seven - Mail Poll",
  "id": "org.cibseven.bpm.extension.mail.poll",
  "version": 1,
  "description": "Poll e-mails from a folder via the CIB seven mail connector (connectorId: mail-poll). IMAP settings come from MAIL_CONFIG.",
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  },
  "keywords": [
    "mail",
    "email",
    "imap",
    "poll",
    "receive",
    "connector"
  ],
  "appliesTo": [
    "bpmn:ServiceTask"
  ],
  "groups": [
    {
      "id": "request",
      "label": "Poll"
    },
    {
      "id": "output",
      "label": "Output mapping"
    }
  ],
  "scopes": [
    {
      "type": "camunda:Connector",
      "properties": [
        {
          "type": "Hidden",
          "value": "mail-poll",
          "binding": {
            "type": "property",
            "name": "connectorId"
          }
        },
        {
          "label": "Folder",
          "group": "request",
          "description": "Mailbox folder to read from.",
          "type": "String",
          "value": "INBOX",
          "binding": {
            "type": "camunda:inputParameter",
            "name": "folder"
          },
          "constraints": {
            "notEmpty": true
          }
        },
        {
          "label": "Mails -> variable",
          "group": "output",
          "description": "Process variable that receives the list of polled mails.",
          "type": "String",
          "value": "mails",
          "binding": {
            "type": "camunda:outputParameter",
            "source": "${mails}"
          }
        }
      ]
    }
  ]
}

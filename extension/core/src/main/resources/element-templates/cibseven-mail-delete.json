{
  "$schema": "https://unpkg.com/@camunda/element-templates-json-schema/resources/schema.json",
  "name": "CIB seven - Mail Delete",
  "id": "org.cibseven.bpm.extension.mail.delete",
  "version": 1,
  "description": "Delete e-mails from a folder via the CIB seven mail connector (connectorId: mail-delete). IMAP settings come from MAIL_CONFIG.",
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  },
  "keywords": [
    "mail",
    "email",
    "imap",
    "delete",
    "connector"
  ],
  "appliesTo": [
    "bpmn:ServiceTask"
  ],
  "groups": [
    {
      "id": "request",
      "label": "Delete"
    }
  ],
  "scopes": [
    {
      "type": "camunda:Connector",
      "properties": [
        {
          "type": "Hidden",
          "value": "mail-delete",
          "binding": {
            "type": "property",
            "name": "connectorId"
          }
        },
        {
          "label": "Folder",
          "group": "request",
          "description": "Mailbox folder to delete from.",
          "type": "String",
          "value": "INBOX",
          "binding": {
            "type": "camunda:inputParameter",
            "name": "folder"
          },
          "constraints": {
            "notEmpty": true
          }
        },
        {
          "label": "Message IDs",
          "group": "request",
          "description": "Provide exactly ONE selector (Message IDs, Message numbers, or Mails). Expression resolving to the RFC Message-ID(s) to delete, e.g. ${messageIds}.",
          "type": "String",
          "optional": true,
          "binding": {
            "type": "camunda:inputParameter",
            "name": "messageIds"
          }
        },
        {
          "label": "Message numbers",
          "group": "request",
          "description": "Alternative selector. Expression resolving to the message number(s) within the folder.",
          "type": "String",
          "optional": true,
          "binding": {
            "type": "camunda:inputParameter",
            "name": "messageNumbers"
          }
        },
        {
          "label": "Mails",
          "group": "request",
          "description": "Alternative selector. Expression resolving to the list of mails to delete, e.g. ${mails} returned by a Mail Poll task.",
          "type": "String",
          "optional": true,
          "binding": {
            "type": "camunda:inputParameter",
            "name": "mails"
          }
        }
      ]
    }
  ]
}
